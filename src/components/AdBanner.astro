---
interface Props {
	slot?: string;
	format?: 'auto' | 'fluid' | 'rectangle';
	position?: 'top' | 'bottom' | 'middle';
}

const { slot, format = 'auto', position = 'middle' } = Astro.props;
---

<div class={`ad-container ad-${position}`} style="margin: 2rem 0; text-align: center; overflow: hidden;">
	<!-- Google AdSense Placeholder -->
	<div class="ad-label" style="font-size: 0.7rem; color: #999; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Advertisement</div>
	<div class="ad-placeholder" style="background: rgba(0,0,0,0.03); border: 1px dashed #ccc; border-radius: 8px; min-height: 250px; display: flex; align-items: center; justify-content: center; position: relative;">
		<span style="color: #888; font-style: italic;">Ad Slot: {slot || 'General'}</span>
		
		{/* 실제 애드센스 코드를 적용할 때 아래 주석을 해제하고 사용하세요 */}
		{/* 
		<ins class="adsbygoogle"
			style="display:block"
			data-ad-client="ca-pub-YOUR_ID_HERE"
			data-ad-slot={slot}
			data-ad-format={format}
			data-full-width-responsive="true"></ins>
		<script>
			(adsbygoogle = window.adsbygoogle || []).push({});
		</script>
		*/}
	</div>
</div>

<style>
	.ad-container {
		width: 100%;
		max-width: 100%;
	}
	.ad-top { margin-top: 0; }
	.ad-bottom { margin-bottom: 0; }
</style>
